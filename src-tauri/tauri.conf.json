{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Oasis Shell",
  "version": "1.1.0",
  "identifier": "com.jibin-jose.oasis-shell",
  "build": {
    "beforeDevCommand": "npm run frontend",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Oasis Shell",
        "width": 1280,
        "height": 900
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
