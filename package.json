{
  "name": "oasis-shell",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:clean": "powershell -ExecutionPolicy Bypass -Command \"if (Test-Path ./tauri-dev.log) { Remove-Item ./tauri-dev.log -Force }; tauri dev *> tauri-dev.log\"",
    "frontend": "vite --port 1420",
    "build": "vite build",
    "build:desktop": "tauri build",
    "preview": "vite preview",
    "tauri": "tauri",
    "sync": "powershell -ExecutionPolicy Bypass -File ./scripts/sync.ps1",
    "smoke": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-check.ps1",
    "smoke:prepare": "powershell -ExecutionPolicy Bypass -File ./scripts/prepare-manual-smoke.ps1",
    "smoke:collect": "powershell -ExecutionPolicy Bypass -File ./scripts/collect-smoke-diagnostics.ps1",
    "smoke:web": "npx -y -p playwright node ./scripts/ui-smoke.cjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@types/three": "^0.183.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "gsap": "^3.14.2",
    "lucide-react": "^1.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-force-graph": "^1.48.2",
    "react-force-graph-3d": "^1.29.1",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.27",
    "playwright": "^1.59.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
